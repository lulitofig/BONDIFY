public class ActividadEducativa extends Actividad{

    private String temaActividad;
    private String nivelDificultad;

    public ActividadEducativa(int idActividad, String nombreActividad, String descripcionActividad, int numeroIntegrantes, boolean comprobante, String temaActividad, String nivelDificultad) {

        //super envia los datos a la clase Actividad para que se guarden
        super(idActividad, nombreActividad, descripcionActividad, numeroIntegrantes, comprobante);

        this.temaActividad = temaActividad;
        this.nivelDificultad = nivelDificultad;
    }
}
